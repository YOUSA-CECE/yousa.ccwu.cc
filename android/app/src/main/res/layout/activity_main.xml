<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#EEF3F8" />

    <ProgressBar
        android:id="@+id/pageProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="top"
        android:max="100"
        android:progressTint="#D76692"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/refreshIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@drawable/refresh_indicator_background"
        android:elevation="5dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingLeft="14dp"
        android:paddingTop="9dp"
        android:paddingRight="14dp"
        android:paddingBottom="9dp"
        android:visibility="invisible">

        <TextView
            android:id="@+id/refreshLogo"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:background="@drawable/splash_logo_background"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="@string/splash_logo"
            android:textColor="#F7C8D8"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/refreshSpinner"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:indeterminateTint="#D76692"
            android:visibility="gone" />

        <TextView
            android:id="@+id/pullHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="9dp"
            android:fontFamily="serif"
            android:text="@string/pull_to_refresh"
            android:textColor="#25303A"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/errorPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#EEF3F8"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:text="@string/load_failed"
            android:textColor="#25303A"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/errorMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="@string/check_network"
            android:textColor="#667582"
            android:textSize="15sp" />

        <Button
            android:id="@+id/retryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="serif"
            android:text="@string/retry"
            android:textAllCaps="false" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/splashPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#EEF3F8"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:background="@drawable/splash_logo_background"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="@string/splash_logo"
            android:textColor="#F7C8D8"
            android:textSize="48sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="serif"
            android:text="@string/site_name"
            android:textColor="#25303A"
            android:textSize="18sp" />

        <ProgressBar
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:indeterminateTint="#D76692" />
    </LinearLayout>
</FrameLayout>
